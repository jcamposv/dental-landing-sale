---
const year = new Date().getFullYear();
---

<footer class="bg-surface-dark text-gray-400 py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <div>
        <img src="/logo.svg" alt="VexaLabs" class="h-7 brightness-0 invert" />
      </div>

      <nav class="flex items-center gap-6 text-sm">
        <a href="#demos" class="hover:text-white transition-colors">Demos</a>
        <a href="#features" class="hover:text-white transition-colors">Features</a>
        <a href="#pricing" class="hover:text-white transition-colors">Precio</a>
        <a href="#faq" class="hover:text-white transition-colors">FAQ</a>
      </nav>

      <p class="text-sm">
        &copy; {year} VexaLabs. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>
