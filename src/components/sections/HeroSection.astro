---
const whatsappLink = "https://wa.me/50670124238?text=Hola%2C%20quiero%20info%20sobre%20las%20p%C3%A1ginas%20web%20para%20dentistas";
---

<section class="relative pt-28 pb-20 sm:pt-36 sm:pb-28 overflow-hidden bg-gradient-to-br from-surface via-white to-blue-50">
  <!-- Decorative circles -->
  <div class="absolute -top-40 -right-40 w-[500px] h-[500px] bg-brand/5 rounded-full blur-3xl"></div>
  <div class="absolute -bottom-40 -left-40 w-[400px] h-[400px] bg-accent/5 rounded-full blur-3xl"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-4xl mx-auto">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 bg-brand/10 text-brand font-semibold text-sm px-4 py-1.5 rounded-full mb-6">
        <span class="w-2 h-2 bg-accent rounded-full animate-pulse"></span>
        Páginas Web Para Dentistas en LATAM
      </div>

      <h1 class="font-display font-extrabold text-4xl sm:text-5xl lg:text-6xl tracking-tight text-surface-dark leading-tight">
        Tu clínica dental merece una
        <span class="text-gradient"> página web profesional</span>
      </h1>

      <p class="mt-6 text-lg sm:text-xl text-gray-600 max-w-2xl mx-auto leading-relaxed">
        Tus pacientes te buscan en Google antes de llamarte. Si no tienes página web,
        <strong class="text-gray-900">estás perdiendo pacientes cada día.</strong>
      </p>

      <!-- CTA buttons -->
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={whatsappLink}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-3 bg-accent hover:bg-accent-dark text-white font-bold text-lg px-8 py-4 rounded-full transition-all shadow-lg shadow-accent/25 hover:shadow-xl hover:shadow-accent/30 hover:-translate-y-0.5"
        >
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Quiero Mi Web — Escríbenos
        </a>
        <a
          href="#demos"
          class="inline-flex items-center gap-2 text-gray-700 hover:text-brand font-semibold text-lg px-6 py-4 rounded-full border-2 border-gray-200 hover:border-brand/30 transition-all"
        >
          Ver Demos
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7"/></svg>
        </a>
      </div>

      <!-- Trust indicators -->
      <div class="mt-14 flex flex-wrap items-center justify-center gap-x-8 gap-y-4 text-sm text-gray-500">
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg>
          Lista en 72 horas
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg>
          WhatsApp integrado
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg>
          Diseño premium o custom
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg>
          Optimizada para Google
        </div>
      </div>
    </div>

    <!-- Stats bar -->
    <div class="mt-16 grid grid-cols-2 sm:grid-cols-4 gap-6 max-w-3xl mx-auto">
      <div class="text-center">
        <div class="font-display font-extrabold text-3xl text-brand">78%</div>
        <div class="text-sm text-gray-500 mt-1">de pacientes buscan en Google</div>
      </div>
      <div class="text-center">
        <div class="font-display font-extrabold text-3xl text-brand">72h</div>
        <div class="text-sm text-gray-500 mt-1">tiempo de entrega</div>
      </div>
      <div class="text-center">
        <div class="font-display font-extrabold text-3xl text-brand">100%</div>
        <div class="text-sm text-gray-500 mt-1">personalizable</div>
      </div>
      <div class="text-center">
        <div class="font-display font-extrabold text-3xl text-brand">$295</div>
        <div class="text-sm text-gray-500 mt-1">USD pago único</div>
      </div>
    </div>
  </div>
</section>
