---
const whatsappLink = "https://wa.me/50670124238?text=QUIERO%20MI%20WEB%20%F0%9F%A6%B7";

const included = [
  "Página web profesional completa",
  "Diseño de ejemplo o personalizado",
  "WhatsApp integrado para citas",
  "Google Calendar (opcional)",
  "SEO optimizado para Google",
  "100% responsive (celular + PC)",
  "Personalización completa",
  "Entrega en 72 horas",
  "1 revisión incluida",
  "Código fuente incluido",
];

const comparison = [
  { item: "Página web profesional", us: "$295", agency: "$1,000 — $3,000" },
  { item: "Tiempo de entrega", us: "72 horas", agency: "2 — 8 semanas" },
  { item: "WhatsApp integrado", us: "Incluido", agency: "+$100 — $300" },
  { item: "SEO básico", us: "Incluido", agency: "+$200 — $500" },
];
---

<section id="pricing" class="py-20 sm:py-28 bg-surface">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16" data-animate>
      <h2 class="font-display font-bold text-3xl sm:text-4xl text-surface-dark">
        Un precio justo, sin sorpresas
      </h2>
      <p class="mt-4 text-gray-600 text-lg">
        Pago único. Sin mensualidades ocultas. Sin contratos.
      </p>
    </div>

    <!-- Pricing card -->
    <div class="max-w-lg mx-auto mb-20" data-animate>
      <div class="relative bg-white rounded-3xl border-2 border-brand shadow-xl shadow-brand/10 overflow-hidden">
        <!-- Popular badge -->
        <div class="bg-brand text-white text-center text-sm font-semibold py-2">
          Oferta de Lanzamiento — Precio Normal: $495 USD
        </div>

        <div class="p-8 sm:p-10 text-center">
          <h3 class="font-display font-bold text-xl text-surface-dark mb-2">Página Web Completa</h3>
          <p class="text-gray-500 text-sm mb-6">Todo lo que necesitas para atraer pacientes online</p>

          <div class="flex items-baseline justify-center gap-2 mb-2">
            <span class="text-gray-400 line-through text-2xl">$495</span>
            <span class="font-display font-extrabold text-6xl text-surface-dark">$295</span>
            <span class="text-gray-500 text-lg">USD</span>
          </div>
          <p class="text-accent font-semibold text-sm mb-8">
            Pago único al recibir tu página
          </p>

          <a
            href={whatsappLink}
            target="_blank"
            rel="noopener"
            class="w-full inline-flex items-center justify-center gap-3 bg-accent hover:bg-accent-dark text-white font-bold text-lg px-8 py-4 rounded-full transition-all shadow-lg shadow-accent/25 hover:shadow-xl"
          >
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Quiero Mi Web — Escríbenos
          </a>

          <p class="text-xs text-gray-400 mt-4">
            Pagas solo cuando tu página está lista y estás 100% satisfecho con el resultado.
          </p>
        </div>

        <div class="border-t border-gray-100 p-8 sm:p-10">
          <p class="font-semibold text-sm text-surface-dark mb-4">Todo esto incluido:</p>
          <div class="grid sm:grid-cols-2 gap-3">
            {included.map((item) => (
              <div class="flex items-start gap-2.5 text-sm text-gray-600">
                <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                {item}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Comparison table -->
    <div data-animate>
      <h3 class="font-display font-bold text-2xl text-center text-surface-dark mb-8">
        Nosotros vs. una agencia tradicional
      </h3>
      <div class="max-w-3xl mx-auto bg-white rounded-2xl border border-gray-100 overflow-hidden">
        <div class="grid grid-cols-3 bg-surface-dark text-white text-sm font-semibold">
          <div class="p-4"></div>
          <div class="p-4 text-center text-accent">VexaLabs</div>
          <div class="p-4 text-center text-gray-400">Agencia</div>
        </div>
        {comparison.map((row, i) => (
          <div class={`grid grid-cols-3 text-sm ${i % 2 === 0 ? "bg-white" : "bg-surface"}`}>
            <div class="p-4 font-medium text-gray-700">{row.item}</div>
            <div class="p-4 text-center font-semibold text-accent">{row.us}</div>
            <div class="p-4 text-center text-gray-400">{row.agency}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
