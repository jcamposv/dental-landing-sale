---
const testimonials = [
  {
    name: "Dr. Carlos Mendoza",
    location: "Ciudad de México, México",
    text: "En menos de 3 días tenía mi página web funcionando. Mis pacientes ahora me encuentran en Google y agendan directo por WhatsApp. La mejor inversión que he hecho.",
    rating: 5,
  },
  {
    name: "Dra. Valentina Rios",
    location: "Bogotá, Colombia",
    text: "Llevo meses queriendo una página web pero las agencias me cobraban más de $1,500. Con VexaLabs obtuve algo mucho mejor por una fracción del precio.",
    rating: 5,
  },
  {
    name: "Dr. Andres Gutierrez",
    location: "Lima, Perú",
    text: "El diseño es profesional, se ve increíble en celular y la integración con WhatsApp es justo lo que necesitaba. Mis pacientes nuevos crecieron un 30% el primer mes.",
    rating: 5,
  },
];
---

<section class="py-20 sm:py-28 bg-surface">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16" data-animate>
      <h2 class="font-display font-bold text-3xl sm:text-4xl text-surface-dark">
        Lo que dicen los doctores
      </h2>
      <p class="mt-4 text-gray-600 text-lg">
        Dentistas en toda Latinoamérica ya tienen su página web profesional.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {testimonials.map((t) => (
        <div data-animate class="bg-white rounded-2xl p-8 border border-gray-100 shadow-sm hover:shadow-md transition-shadow">
          <!-- Stars -->
          <div class="flex gap-1 mb-4">
            {Array.from({ length: t.rating }).map(() => (
              <svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <p class="text-gray-600 leading-relaxed mb-6 text-sm">"{t.text}"</p>

          <div>
            <p class="font-display font-bold text-surface-dark">{t.name}</p>
            <p class="text-sm text-gray-500">{t.location}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
